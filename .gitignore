# Godot 4+ specific ignores
.godot/
/android/

# Godot 4: DO NOT ignore *.import files! 
# (They store import settings)
!*.import

*.translation
*.pck

# Export configuration and credentials
export.cfg
export_credentials.cfg

# Build artifacts
build/
dist/

# Mono/C# specific ignores
.mono/
*.csproj
*.sln
*.gen.cpp
*.gen.h

# OS-specific
.DS_Store
Thumbs.db
desktop.ini

# Large Binary Files
*.a
*.xcframework/
*.zip

# Backup files
*.tmp
*.bak
*.swp

# Editor/Tools
.vscode/
.idea/
.gemini/
*.uid
